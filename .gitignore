# bismuth .gitignore

# Binaries
/bin/
*.exe
*.dll
*.so
*.dylib

# Test artifacts
/test/
/coverage.out

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Local config / secrets
config.yaml
config.local.yaml
*.env
.env

# Runtime data
/data/
/db/
# Per-agent workdir: git worktrees + scratch created when spawning agents
.bismuth/
*.db
*.db-shm
*.db-wal

# Node
node_modules/
dist/
.vite/
*.tsbuildinfo
*.js
!web/node_modules/.package-lock.json

# Logs
*.log
logs/
node_modules/
